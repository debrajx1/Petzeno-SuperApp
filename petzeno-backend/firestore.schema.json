{
  "users": {
    "__doc__": "User profiles (Pet Owners & Providers)",
    "fields": {
      "uid": "string",
      "name": "string",
      "email": "string",
      "role": "'owner' | 'vet' | 'shelter' | 'store'",
      "createdAt": "timestamp"
    }
  },
  "pets": {
    "__doc__": "Pet profiles and health records",
    "fields": {
      "petId": "string",
      "ownerId": "string (users.uid)",
      "name": "string",
      "species": "string",
      "breed": "string",
      "dob": "timestamp",
      "weight": "number",
      "healthRecords": [
        {
          "type": "'vaccination' | 'surgery' | 'checkup'",
          "date": "timestamp",
          "notes": "string",
          "vetId": "string (users.uid)"
        }
      ]
    }
  },
  "appointments": {
    "__doc__": "Vet booking records",
    "fields": {
      "appointmentId": "string",
      "petId": "string",
      "ownerId": "string",
      "clinicId": "string",
      "doctorName": "string",
      "dateTime": "timestamp",
      "reason": "string",
      "status": "'pending' | 'confirmed' | 'completed' | 'cancelled'"
    }
  },
  "shelterListings": {
    "__doc__": "Adoption listings and lost/found",
    "fields": {
      "listingId": "string",
      "shelterId": "string (users.uid)",
      "type": "'adoption' | 'lost' | 'found'",
      "petDetails": {
        "name": "string",
        "species": "string",
        "breed": "string",
        "age": "string",
        "description": "string"
      },
      "status": "'available' | 'pending' | 'adopted' | 'resolved'",
      "createdAt": "timestamp"
    }
  },
  "storeInventory": {
    "__doc__": "Product inventory for pet stores",
    "fields": {
      "sku": "string",
      "storeId": "string (users.uid)",
      "name": "string",
      "category": "string",
      "price": "number",
      "stockQuantity": "number",
      "status": "'instock' | 'lowstock' | 'outofstock'"
    }
  },
  "communityPosts": {
    "__doc__": "Social feed posts",
    "fields": {
      "postId": "string",
      "authorId": "string",
      "content": "string",
      "hasImage": "boolean",
      "likesCount": "number",
      "commentsCount": "number",
      "createdAt": "timestamp"
    }
  }
}
